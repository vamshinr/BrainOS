# =============================================================================
# BrainOS frontend (Next.js) configuration
# =============================================================================
# Copy to `.env.local` and fill in for local development.
#
# In Docker, `docker-compose.yml` sets BACKEND_URL=http://backend:8081 and you
# don't need this file at all.
# =============================================================================

# URL of the Python backend the Next.js API routes proxy to.
# Leave commented for local dev (defaults to http://localhost:8081).
# Set to your deployed backend's address when running the frontend separately.
# BACKEND_URL=http://localhost:8081
