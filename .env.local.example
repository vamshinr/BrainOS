# Recommended: a single key via Vercel AI Gateway
# AI_GATEWAY_API_KEY=ai-gw-...

# Or use a direct provider key (auto-detected by AI SDK)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Override the model the brain uses for extraction, reconciliation, and Q&A.
# Defaults to openai/gpt-4o-mini.
# BRAIN_OS_MODEL=anthropic/claude-sonnet-4.5
