# =============================================================================
# BrainOS backend configuration
# =============================================================================
# Copy this file to `src/python_backend/.env` and fill in your values.
# Anything left commented uses the documented default.
#
# Two ways to run the LLM. Pick ONE:
#   • Provider A — Anthropic Claude API (easiest, just an API key)
#   • Provider B — Self-hosted OpenAI-compatible endpoint (vLLM, TGI, Ollama,
#                  llama.cpp server, etc.)
# Toggle with LLM_PROVIDER below.
# =============================================================================


# ── Provider toggle ──────────────────────────────────────────────────────────
# Values: claude  | custom
# Leave unset for auto-detect (prefers `custom` if reachable, else `claude`).
LLM_PROVIDER=claude


# ── Provider A: Claude API ───────────────────────────────────────────────────
# Required when LLM_PROVIDER=claude.
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001


# ── Provider B: Self-hosted OpenAI-compatible endpoint ───────────────────────
# Required when LLM_PROVIDER=custom. Examples:
#
#   vLLM:   http://<host>:8000/v1
#   Ollama: http://<host>:11434/v1
#   TGI:    http://<host>:8080/v1
#
# Leave empty (and LLM_PROVIDER=claude) if you're only using the Claude API.
LLM_API_BASE=
MODEL_NAME=

# Optional: separate vision-language endpoint for image ingestion.
# If empty, falls back to LLM_API_BASE (Claude has vision natively).
VLM_API_BASE=
VLM_MODEL_NAME=


# ── Per-task routing (advanced, custom-provider only) ────────────────────────
# Split work across two or more endpoints/models. Each variable is optional;
# anything missing falls back to LLM_API_BASE + MODEL_NAME above. Useful when
# you want a heavy 70B on extraction and a cheap 7B on reconciliation.
#
# EXTRACTION_API_BASE=http://gpu1:8000/v1
# EXTRACTION_MODEL=meta-llama/Llama-3.1-70B-Instruct
# RECONCILE_API_BASE=http://gpu2:8000/v1
# RECONCILE_MODEL=Qwen/Qwen2.5-7B-Instruct
# EXECUTE_MODEL=
# FEEDBACK_MODEL=


# ── Embeddings ───────────────────────────────────────────────────────────────
# CPU default: sentence-transformers, downloads ~90 MB on first start.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# GPU option: serve an embedding model with vLLM on a separate port, then point
# BrainOS at it (clear the vector store after switching: `curl -X DELETE
# http://localhost:8081/api/clear`).
# EMBEDDING_API_BASE=http://<host>:8002/v1
# EMBEDDING_MODEL=BAAI/bge-large-en-v1.5


# ── Data ──────────────────────────────────────────────────────────────────────
# Where BrainOS persists state (brain.json + chroma_db/). In Docker this is the
# mounted volume; locally it defaults to ../data relative to this file.
# BRAIN_DATA_DIR=/data


# ── Behavior ──────────────────────────────────────────────────────────────────
# Comma-separated topics the auto-answer pipeline will refuse to answer about.
SENSITIVE_TOPICS=salary


# ── Slack MCP (optional) ─────────────────────────────────────────────────────
# Required only if you connect a Slack workspace via /slack.
# SLACK_MCP_APP_ID=
# SLACK_MCP_ACCESS_TOKEN=
# SLACK_SIGNING_SECRET=
# SLACK_BOT_USER_ID=
# SLACK_DEFAULT_DEPARTMENT=engineering
# SLACK_ALLOWED_CHANNELS=
# SLACK_AUTO_ANSWER_CHANNELS=
# SLACK_AUTO_ANSWER_PREFIXES=brainos:
